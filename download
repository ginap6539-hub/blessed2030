// --- MESSAGE SERVICE ---
export const messageService = {
    getMessages: async (user1: string, user2: string) => {
        // If user2 is GLOBAL_BROADCAST, get all broadcast messages
        if (user2 === 'GLOBAL_BROADCAST') {
            const { data } = await supabase.from('messages')
                .select('*')
                .eq('is_broadcast', true)
                .order('created_at', { ascending: true })
                .limit(100);
            return data || [];
        }

        const { data } = await supabase.from('messages')
            .select('*')
            .or(`and(sender_id.eq.${user1},receiver_id.eq.${user2}),and(sender_id.eq.${user2},receiver_id.eq.${user1})`)
            .order('created_at', { ascending: true })
            .limit(100);
        return data || [];
    },

    sendMessage: async (msg: any) => {
        const { error } = await supabase.from('messages').insert({
            sender_id: msg.senderId,
            receiver_id: msg.receiverId === 'GLOBAL_BROADCAST' ? null : msg.receiverId,
            text: msg.text,
            is_broadcast: msg.isBroadcast || false
        });
        if (error) throw error;
    },

    getAllUserConversations: async () => {
        const { data: admin } = await supabase.from('profiles').select('id').eq('email', 'admin@blessed.ph').single();
        if (!admin) return [];
        
        const { data: messages } = await supabase.from('messages')
            .select('sender_id, receiver_id')
            .or(`sender_id.eq.${admin.id},receiver_id.eq.${admin.id}`)
            .order('created_at', { ascending: false });
            
        if (!messages) return [];
        
        const userIds = new Set<string>();
        messages.forEach(m => {
            if (m.sender_id !== admin.id) userIds.add(m.sender_id);
            if (m.receiver_id !== admin.id) userIds.add(m.receiver_id);
        });
        
        if (userIds.size === 0) return [];
        
        const { data: profiles } = await supabase.from('profiles').select('id, first_name, last_name').in('id', Array.from(userIds));
        
        return profiles?.map(p => ({
            userId: p.id,
            userName: `${p.first_name} ${p.last_name}`
        })) || [];
    },

    subscribe: (callback: (payload?: any) => void) => {
        const channel = supabase.channel('public:messages')
            .on('postgres_changes', { event: 'INSERT', schema: 'public', table: 'messages' }, callback)
            .subscribe();
        return () => { supabase.removeChannel(channel); };
    }
};

// --- WALLET SERVICE ---
export const walletService = {
    getTransactions: async (userId?: string) => {
        let query = supabase.from('wallet_transactions').select('*').order('created_at', { ascending: false }).limit(50);
        if (userId) query = query.eq('user_id', userId);
        const { data } = await query;
        return data || [];
    },

    getTotalCirculatingSupply: async () => {
        const { data } = await supabase.from('profiles').select('wallet_balance');
        if (!data) return 0;
        return data.reduce((acc, curr) => acc + (curr.wallet_balance || 0), 0);
    },

    createTransaction: async (tx: any, adminId?: string) => {
        await supabase.from('wallet_transactions').insert({
            ...tx,
            admin_id: adminId
        });
    },

    approveTransaction: async (tx: any, adminId: string) => {
        await supabase.from('wallet_transactions').update({
            status: 'APPROVED',
            admin_id: adminId
        }).eq('id', tx.id);

        // Update balance based on type
        if (tx.type === 'CASH_IN') {
            const { data: profile } = await supabase.from('profiles').select('wallet_balance').eq('id', tx.user_id).single();
            if (profile) {
                await supabase.from('profiles').update({ wallet_balance: (profile.wallet_balance || 0) + tx.amount }).eq('id', tx.user_id);
            }
        } else if (tx.type === 'CASH_OUT') {
            const { data: profile } = await supabase.from('profiles').select('wallet_balance').eq('id', tx.user_id).single();
            if (profile) {
                await supabase.from('profiles').update({ wallet_balance: (profile.wallet_balance || 0) - tx.amount }).eq('id', tx.user_id);
            }
        }
    },
    
    rejectTransaction: async (txId: string, adminId: string) => {
        await supabase.from('wallet_transactions').update({
            status: 'REJECTED',
            admin_id: adminId
        }).eq('id', txId);
    },

    grantEmergencyFund: async (adminId: string, user: any, amount: number) => {
        await walletService.createTransaction({
            user_id: user.id,
            user_name: `${user.first_name} ${user.last_name}`,
            type: 'EMERGENCY_GRANT',
            amount,
            status: 'APPROVED',
            reference_code: `EG-${Date.now()}`
        }, adminId);
        
        // Update user balance
        const { data: profile } = await supabase.from('profiles').select('wallet_balance').eq('id', user.id).single();
        if (profile) {
            await supabase.from('profiles').update({ wallet_balance: (profile.wallet_balance || 0) + amount }).eq('id', user.id);
        }
    },

    massDeductEmergencyFund: async (amount: number, adminId: string, title?: string, desc?: string) => {
        const { data: users } = await supabase.from('profiles').select('id, wallet_balance');
        if (!users) return { totalDeducted: 0, userCount: 0 };
        
        let total = 0;
        let count = 0;
        
        for (const u of users) {
            if ((u.wallet_balance || 0) >= amount) {
                await supabase.from('profiles').update({ wallet_balance: (u.wallet_balance || 0) - amount }).eq('id', u.id);
                await walletService.createTransaction({
                    user_id: u.id,
                    type: 'EMERGENCY_DEDUCTION',
                    amount,
                    status: 'APPROVED',
                    reference_code: `ED-MASS-${Date.now()}`,
                    withdrawal_details: title
                }, adminId);
                total += amount;
                count++;
            }
        }
        return { totalDeducted: total, userCount: count };
    },

    requestCashIn: async (user: any, amount: number, referenceCode: string) => {
        await walletService.createTransaction({
            user_id: user.id,
            user_name: `${user.first_name} ${user.last_name}`,
            type: 'CASH_IN',
            amount,
            reference_code: referenceCode,
            status: 'PENDING'
        });
    },

    requestCashOut: async (user: any, amount: number, accountInfo: string) => {
        await walletService.createTransaction({
            user_id: user.id,
            user_name: `${user.first_name} ${user.last_name}`,
            type: 'CASH_OUT',
            amount,
            reference_code: accountInfo,
            status: 'PENDING'
        });
    },

    sendCoins: async (user: any, receiverCode: string, amount: number) => {
        // Check balance
        const { data: senderProfile } = await supabase.from('profiles').select('wallet_balance').eq('id', user.id).single();
        if (!senderProfile || (senderProfile.wallet_balance || 0) < amount) throw new Error("Insufficient balance");

        // Find receiver by wallet_code
        const { data: receiverProfile } = await supabase.from('profiles').select('id, wallet_balance, first_name, last_name').eq('wallet_code', receiverCode).maybeSingle();
        if (!receiverProfile) throw new Error("Recipient digital code not found.");
        
        const receiverId = receiverProfile.id;

        // Deduct from sender
        await supabase.from('profiles').update({ wallet_balance: (senderProfile.wallet_balance || 0) - amount }).eq('id', user.id);
        
        // Add to receiver
        await supabase.from('profiles').update({ wallet_balance: (receiverProfile.wallet_balance || 0) + amount }).eq('id', receiverId);

        // Record transaction for sender
        await walletService.createTransaction({
            user_id: user.id,
            user_name: `${user.first_name} ${user.last_name}`,
            target_user_id: receiverId,
            target_user_name: `${receiverProfile.first_name} ${receiverProfile.last_name}`,
            type: 'TRANSFER_SEND',
            amount,
            status: 'APPROVED',
            reference_code: `TR-S-${Date.now()}`
        });

        // Record transaction for receiver
        await walletService.createTransaction({
            user_id: receiverId,
            user_name: `${receiverProfile.first_name} ${receiverProfile.last_name}`,
            target_user_id: user.id,
            target_user_name: `${user.first_name} ${user.last_name}`,
            type: 'TRANSFER_RECEIVE',
            amount,
            status: 'APPROVED',
            reference_code: `TR-R-${Date.now()}`
        });
    },

    subscribe: (callback: () => void) => {
        const channel = supabase.channel('public:wallet')
            .on('postgres_changes', { event: '*', schema: 'public', table: 'wallet_transactions' }, callback)
            .subscribe();
        return () => { supabase.removeChannel(channel); };
    },
    
    grantRewardPoints: async (adminId: string, userId: string, points: number, orderId: string) => {
        const { data: profile } = await supabase.from('profiles').select('wallet_balance').eq('id', userId).single();
        if (profile) {
            await supabase.from('profiles').update({ wallet_balance: (profile.wallet_balance || 0) + points }).eq('id', userId);
        }
        
        await walletService.createTransaction({
            user_id: userId,
            type: 'PURCHASE_POINTS',
            amount: points,
            status: 'APPROVED',
            reference_code: `REW-${orderId}`
        }, adminId);
    }
};

// --- STORAGE SERVICE ---
export const storageService = {
    uploadImage: async (file: File, bucketName: string = 'cms-assets') => {
        const fileExt = file.name.split('.').pop();
        const fileName = `${Math.random()}.${fileExt}`;
        const { data: { user } } = await supabase.auth.getUser();
        
        // Ensure bucket name is valid, fallback to cms-assets if empty
        const targetBucket = bucketName || 'cms-assets';
        
        // CMS assets should always be in a 'public/' folder for easier policy management
        // regardless of who uploads them, so the public can always view them.
        const filePath = `public/${fileName}`;

        const { error: uploadError } = await supabase.storage.from(targetBucket).upload(filePath, file);
        
        if (uploadError) {
            console.error("Supabase Storage Upload Error:", uploadError);
            if (uploadError.message.includes('row-level security policy')) {
                throw new Error("STORAGE POLICY ERROR: Your account has permission to log in, but NOT to upload files. You must enable 'INSERT' and 'SELECT' permissions for the 'authenticated' role on the '" + targetBucket + "' bucket in your Supabase Dashboard.");
            }
            throw uploadError;
        }

        const { data } = supabase.storage.from(targetBucket).getPublicUrl(filePath);
        return data.publicUrl;
    }
};

