// --- CMS SERVICE ---
export const cmsService = {
    getContent: async () => {
        const { data } = await supabase.from('website_content').select('*').limit(1).single();
        if (data) return data.content;
        return null;
    },

    updateContent: async (content: any) => {
        const { data, error: fetchError } = await supabase.from('website_content').select('id').limit(1);
        if (fetchError) throw fetchError;

        if (data && data.length > 0) {
            const { error: updateError } = await supabase.from('website_content').update({ content: content }).eq('id', data[0].id);
            if (updateError) throw updateError;
        } else {
            const { error: insertError } = await supabase.from('website_content').insert({ id: 'main', content: content });
            if (insertError) throw insertError;
        }
    },

    subscribe: (callback: (data: any) => void) => {
        const channel = supabase.channel('public:website_content')
            .on('postgres_changes', { event: '*', schema: 'public', table: 'website_content' }, (payload) => {
                if (payload.new && (payload.new as any).content) {
                    callback((payload.new as any).content);
                }
            })
            .subscribe();
        return () => { supabase.removeChannel(channel); };
    }
};

// --- AUTH SERVICE ---
export const authService = {
    login: async (email: string, password: string) => {
        const { data, error } = await supabase.auth.signInWithPassword({ email, password });
        if (error) throw error;
        return authService.getCurrentUser();
    },

    register: async (data: any) => {
        const { email, password, firstName, middleName, lastName, position, region, avatarUrl, memberLogoUrl, address, phone, lat, lng } = data;
        
        // 1. Check if user already exists in auth
        let userId: string | null = null;
        
        const { data: authData, error: signUpError } = await supabaseAdmin.auth.admin.createUser({
            email,
            password,
            email_confirm: true, // AUTO-CONFIRM
            user_metadata: {
                first_name: firstName,
                last_name: lastName,
                full_name: `${firstName} ${lastName}`
            }
        });
        
        if (signUpError) {
            // If user already exists, try to find them
            if (signUpError.message.includes('already registered') || signUpError.message.includes('already exists')) {
                const { data: usersData, error: listError } = await supabaseAdmin.auth.admin.listUsers();
                if (listError) throw listError;
                const existingUser = (usersData.users as any[]).find((u: any) => u.email === email);
                if (existingUser) {
                    userId = existingUser.id;
                } else {
                    throw signUpError;
                }
            } else {
                throw signUpError;
            }
        } else {
            userId = authData.user.id;
        }
        
        if (!userId) throw new Error("Authentication failed: User ID not found.");
        
        // 2. Check if Profile exists
        const { data: existingProfile } = await supabase
            .from('profiles')
            .select('id')
            .eq('id', userId)
            .single();

        if (existingProfile) {
            throw new Error("User already registered with a complete profile. Please login instead.");
        }

        // 3. Create Profile
        const newProfile = {
            id: userId,
            email,
            role: email === 'admin@blessed.ph' ? 'ADMIN' : 'MEMBER',
            first_name: firstName,
            middle_name: middleName,
            last_name: lastName,
            position: position,
            region: region,
            avatar_url: avatarUrl,
            member_logo_url: memberLogoUrl,
            address: address,
            phone: phone,
            wallet_balance: 0,
            is_online: true,
            last_active: new Date().toISOString(),
            last_lat: lat,
            last_lng: lng,
            joined_at: new Date().toISOString()
        };

        const { error: profileError } = await supabase
            .from('profiles')
            .insert(newProfile);

        if (profileError) {
            console.error("Profile creation fault:", profileError);
            throw new Error(`Profile creation failed: ${profileError.message}`);
        }

        // 4. Log in the user locally
        const { data: loginData, error: loginError } = await supabase.auth.signInWithPassword({
            email,
            password
        });
        
        if (loginError) throw loginError;
        return authService.getCurrentUser();
    },

    logout: async () => {
        await supabase.auth.signOut();
    },

    getCurrentUser: async () => {
        const { data: { user } } = await supabase.auth.getUser();
        if (!user) return null;
        
        const { data: profile, error } = await supabase
            .from('profiles')
            .select('*')
            .eq('id', user.id)
            .single();
            
        if (!profile && user.email === 'admin@blessed.ph') {
            // Auto-create admin profile if it doesn't exist
            const newProfile = {
                id: user.id,
                email: user.email,
                role: 'ADMIN',
                first_name: 'System',
                last_name: 'Admin',
                wallet_balance: 0,
                is_online: true,
                joined_at: new Date().toISOString()
            };
            await supabase.from('profiles').insert(newProfile);
            return { ...newProfile, email: user.email };
        }
            
        return profile ? { ...profile, email: user.email } : null;
    },

    getUserProfileById: async (userId: string) => {
        const { data } = await supabase.from('profiles').select('*').eq('id', userId).single();
        return data;
    },

    getAdminProfile: async () => {
        const { data } = await supabase.from('profiles').select('*').eq('email', 'admin@blessed.ph').maybeSingle();
        return data;
    },

    updateUser: async (userId: string, updates: any) => {
        await supabase.from('profiles').update(updates).eq('id', userId);
    },

    getAllUsers: async () => {
        const { data } = await supabase.from('profiles').select('*, last_lat, last_lng');
        return data || [];
    },
    
    getTotalUserCount: async () => {
        const { count } = await supabase.from('profiles').select('*', { count: 'exact', head: true });
        return count || 0;
    },

    getOnlineUsers: async () => {
        const { data, count } = await supabase
            .from('profiles')
            .select('*', { count: 'exact' })
            .eq('is_online', true);
        return data || [];
    },

    searchUsers: async (term: string) => {
        const { data } = await supabase
            .from('profiles')
            .select('*')
            .or(`email.ilike.%${term}%,first_name.ilike.%${term}%,last_name.ilike.%${term}%,wallet_code.ilike.%${term}%`)
            .limit(50);
        return data || [];
    },

    forgotPassword: async (email: string) => {
        await supabase.auth.resetPasswordForEmail(email, {
            redirectTo: `${window.location.origin}/auth/reset-password`,
        });
    },

    adminResetPassword: async (userId: string, newPass: string) => {
        const { error } = await supabase.auth.admin.updateUserById(userId, { password: newPass });
        if (error) throw error;
    },

    subscribe: (callback: () => void) => {
        const channel = supabase.channel('public:profiles')
            .on('postgres_changes', { event: '*', schema: 'public', table: 'profiles' }, callback)
            .subscribe();
        return () => { supabase.removeChannel(channel); };
    }
};

