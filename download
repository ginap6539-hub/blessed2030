// --- PAYOUT SERVICE ---
export const payoutService = {
    getPayouts: async () => {
        const { data } = await supabase.from('payouts').select('*').order('created_at', { ascending: false }).limit(50);
        return data || [];
    },

    getPayoutsForUser: async (userId: string) => {
        const { data } = await supabase.from('payouts').select('*').eq('user_id', userId).order('created_at', { ascending: false }).limit(20);
        return data || [];
    },

    requestPayout: async (payout: any) => {
        // Deduct balance immediately
        const { data: profile } = await supabase.from('profiles').select('wallet_balance').eq('id', payout.userId).single();
        if (!profile || (profile.wallet_balance || 0) < payout.amount) throw new Error("Insufficient balance");
        
        await supabase.from('profiles').update({ wallet_balance: (profile.wallet_balance || 0) - payout.amount }).eq('id', payout.userId);
        
        await supabase.from('payouts').insert({
            user_id: payout.userId,
            user_name: payout.userName,
            amount: payout.amount,
            account_number: payout.accountNumber,
            chapter: payout.chapter,
            id_url: payout.idUrl,
            status: 'PENDING'
        });

        // Record transaction
        await walletService.createTransaction({
            user_id: payout.userId,
            user_name: payout.userName,
            type: 'CASH_OUT',
            amount: payout.amount,
            status: 'PENDING',
            reference_code: `PO-${Date.now()}`
        });
    },

    rejectPayout: async (id: string, reason: string) => {
        const { data: payout } = await supabase.from('payouts').select('*').eq('id', id).single();
        if (!payout) return;

        await supabase.from('payouts').update({ status: 'REJECTED', message: reason }).eq('id', id);

        // Refund balance
        const { data: profile } = await supabase.from('profiles').select('wallet_balance').eq('id', payout.user_id).single();
        if (profile) {
            await supabase.from('profiles').update({ wallet_balance: (profile.wallet_balance || 0) + payout.amount }).eq('id', payout.user_id);
        }
    },

    approvePayout: async (id: string, proofUrl: string, message: string) => {
        await supabase.from('payouts').update({
            status: 'APPROVED',
            admin_proof_url: proofUrl,
            message
        }).eq('id', id);
    },

    subscribe: (callback: () => void) => {
        const channel = supabase.channel('public:payouts')
            .on('postgres_changes', { event: '*', schema: 'public', table: 'payouts' }, callback)
            .subscribe();
        return () => { supabase.removeChannel(channel); };
    }
};

// --- UPGRADE SERVICE ---
export const upgradeService = {
    getUpgradeRequests: async () => {
        const { data } = await supabase.from('upgrade_requests').select('*').order('created_at', { ascending: false }).limit(50);
        return data || [];
    },

    requestUpgrade: async (userId: string, userName: string, proofUrl: string) => {
        await supabase.from('upgrade_requests').insert({
            user_id: userId,
            user_name: userName,
            proof_url: proofUrl,
            status: 'PENDING'
        });
    },

    approveUpgrade: async (requestId: string, userId: string) => {
        await supabase.from('upgrade_requests').update({ status: 'APPROVED' }).eq('id', requestId);
        await supabase.from('profiles').update({ is_exclusive: true, membership_status: 'Exclusive' }).eq('id', userId);
    },

    rejectUpgrade: async (requestId: string) => {
        await supabase.from('upgrade_requests').update({ status: 'REJECTED' }).eq('id', requestId);
    },

    subscribe: (callback: () => void) => {
        const channel = supabase.channel('public:upgrades')
            .on('postgres_changes', { event: '*', schema: 'public', table: 'upgrade_requests' }, callback)
            .subscribe();
        return () => { supabase.removeChannel(channel); };
    }
};

// --- NOTIFICATION SERVICE ---
export const notificationService = {
    getNotifications: async (userId: string) => {
        const { data } = await supabase.from('notifications').select('*').eq('user_id', userId).order('created_at', { ascending: false }).limit(20);
        return data || [];
    },
    
    markAsRead: async (id: string) => {
        await supabase.from('notifications').update({ is_read: true }).eq('id', id);
    },
    
    subscribe: (userId: string, callback: (payload?: any) => void) => {
        const channel = supabase.channel(`public:notifications:${userId}`)
            .on('postgres_changes', { event: 'INSERT', schema: 'public', table: 'notifications', filter: `user_id=eq.${userId}` }, callback)
            .subscribe();
        return () => { supabase.removeChannel(channel); };
    }
};