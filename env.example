    title: "Core Values",
    content: "CORE VALUES:\n- Love of God\n- Love of Country\n- Integrity\n- Stewardship\n- Unity\n- Service"
  },
  VISION_MISSION: {
      title: "Vision & Mission",
      content: "VISION: A just and prosperous Philippines with integrity, unity, and eliminated corruption.\nMISSION: To engage communities in nation-building and combat corruption through advocacy, community engagement, and strategic partnerships."
  },
  DREAMS_TO_GOALS: {
      title: "Dreams to Goals",
      content: "Transforming Dreams into Goals requires:\n1. Specificity (What exactly?)\n2. Timeline (When?)\n3. Cost (How much?)\n4. Action Plan (How?)\nUse the Financial Planning Formula to break down the cost into daily targets."
  }
};

export const getRegistryData = (key: string): { title: string; content: string } => {
  return REGISTRY_DATA[key] || { title: "Error", content: "Registry Link established. Please query a specific Booklet category." };
};

export const getRegistryTopics = (): { key: string; title: string }[] => {
  return Object.entries(REGISTRY_DATA).map(([key, value]) => ({
    key,
    title: value.title,
  }));
};

// Smart response generator
export const getNyxResponse = (prompt: string): string => {
    const p = prompt.toLowerCase();
    
    if (p.includes('earn') || p.includes('money') || p.includes('job') || p.includes('business') || p.includes('quadrant')) {
        return REGISTRY_DATA["4_WAYS_TO_EARN"].content;
    }
    if (p.includes('success') || p.includes('step') || p.includes('guide')) {
        return REGISTRY_DATA["7_STEPS"].content;
    }
    if (p.includes('area') || p.includes('life') || p.includes('personal')) {
        return REGISTRY_DATA["6_AREAS"].content;
    }
    if (p.includes('oath') || p.includes('promise') || p.includes('swear')) {
        return REGISTRY_DATA["OATH"].content;
    }
    if (p.includes('financial') || p.includes('plan') || p.includes('formula')) {
        return REGISTRY_DATA["FINANCIAL_FORMULA"].content;
    }
    if (p.includes('save') || p.includes('saving') || p.includes('jar')) {
        return REGISTRY_DATA["SAVINGS_JAR"].content;
    }
    if (p.includes('value') || p.includes('core')) {
        return REGISTRY_DATA["CORE_VALUES"].content;
    }
    if (p.includes('mission') || p.includes('vision')) {
        return REGISTRY_DATA["VISION_MISSION"].content;
    }
    if (p.includes('goal') || p.includes('dream')) {
        return REGISTRY_DATA["DREAMS_TO_GOALS"].content;
    }
    
    return "This inquiry requires specific referencing from Book 1 or Book 2. I can explain the '7 Steps to Success', '4 Ways to Earn', '6 Areas of Success', or recite the 'Oath'. What do you need?";
};
