<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Blessed Movement | Blessed Access</title>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700&family=Inter:wght@300;400;600;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://esm.sh/leaflet@1.9.4/dist/leaflet.css" crossorigin=""/>
    <style>
      body {
        background-color: #0F172A;
        color: #F8FAFC;
        overflow-x: hidden;
      }
      /* Custom Scrollbar */
      ::-webkit-scrollbar {
        width: 8px;
      }
      ::-webkit-scrollbar-track {
        background: #0F172A;
      }
      ::-webkit-scrollbar-thumb {
        background: #003366;
        border-radius: 4px;
      }
      ::-webkit-scrollbar-thumb:hover {
        background: #FFC107;
      }
      .custom-scrollbar::-webkit-scrollbar {
        width: 4px;
      }
      .leaflet-container {
        height: 400px;
        width: 100%;
        border-radius: 1.5rem;
      }
    </style>
</head>
  <body>
    <div id="root"></div>
    <script type="module" src="/index.tsx"></script>
  </body>
</html>